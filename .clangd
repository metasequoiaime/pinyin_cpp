CompileFlags:
  Add: [
      -DUNICODE,
      -D_UNICODE,
      "-std=c++17", # needed when using MSVC
      "-IC:/Users/SonnyCalcr/EDisk/CppCodes/IMECodes/Experiments/pinyin_expe/pinyin_cpp/build/vcpkg_installed/x64-windows/include",
      -Wno-microsoft-goto,
      -Wno-nonportable-include-path,
      -Wno-microsoft-extra-qualification,
      -Wunused-variable,
      # -Wno-unused-value,
    ] # ignore some specific warnings
  CompilationDatabase: build/ # Search build/ directory for compile_commands.json
